# Copy this file to .env and fill in your own values.
# This tool uses OAuth (via the BigQuery MCP server) for authentication --
# there is no API key or service-account file to put here. .env just tells
# scripts/queries which project to target.

# Your own GCP project ID containing the BigQuery dataset you want to analyze.
GCP_PROJECT_ID=your-gcp-project-id

# The BigQuery dataset to analyze within that project.
GCP_DATASET=your-dataset-name
