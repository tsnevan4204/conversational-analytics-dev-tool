# Copy this file to .env and fill in your own values.
# Only needed for BigQuery -- skip this file entirely if you're analyzing
# local CSV/JSON/Parquet files instead.
#
# Auth is separate from this file: run `gcloud auth application-default
# login` once (see README) before BigQuery queries will work. There's no
# API key or service-account file to put here -- .env just tells Claude
# which project/dataset to target.

# Your own GCP project ID containing the BigQuery dataset you want to analyze.
GCP_PROJECT_ID=your-gcp-project-id

# The BigQuery dataset to analyze within that project.
GCP_DATASET=your-dataset-name
