# Local environment / secrets
.env
.claude/settings.local.json
*.json
!.mcp.json
service-account*.json
*.key

# Python
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Scratch outputs -- per-machine, not checked in
outputs/*
